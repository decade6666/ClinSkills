{
  "permissions": {
    "deny": [
      "Edit(**/*.ipynb)",
      "Write(**/*.ipynb)",
      "NotebookEdit(**/*.ipynb)"
    ],
    "allow": [
      "Read(**)",
      "Glob(**)",
      "Grep(**)",
      "Edit(04 scripts/**)",
      "Edit(utils/**)",
      "Edit(config.py)",
      "Edit(config.yaml)",
      "Edit(注意事项.md)",
      "Edit(.gitignore)",
      "Edit(CLAUDE.md)",
      "Edit(.claude/**)",
      "Write(04 scripts/**)",
      "Write(utils/**)",
      "Bash(python 04 scripts/**)",
      "Bash(python \"04 scripts/**\")",
      "Bash(python .claude/skills/**)",
      "Bash(pip install *)",
      "Bash(git *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Read|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "python ${CLAUDE_PROJECT_DIR}/.claude/hooks/raw_read_guard.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python ${CLAUDE_PROJECT_DIR}/.claude/hooks/syntax_check.py"
          }
        ]
      }
    ]
  }
}
