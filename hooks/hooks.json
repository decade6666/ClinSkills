{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Read|PowerShell|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PLUGIN_ROOT/scripts/raw_read_guard.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PLUGIN_ROOT/scripts/syntax_check.py\""
          }
        ]
      }
    ]
  }
}
