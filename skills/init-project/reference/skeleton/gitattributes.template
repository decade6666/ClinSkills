# Auto detect text files and normalize line endings to LF in repository
* text=auto eol=lf

# Explicitly declare text types
*.py text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.txt text eol=lf

# Binary files
*.xlsx binary
*.docx binary
*.png binary
*.jpg binary
